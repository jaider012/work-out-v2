{
  "name": "work-out-v2",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "e2e": "maestro test .maestro",
    "e2e:flow": "maestro test",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native|react-native-worklets|@react-navigation|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-native-.*|@react-native-.*|expo-modules-core)"
    ]
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.9",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.2.2",
    "expo": "~55.0.15",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.14",
    "expo-crypto": "~55.0.14",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-linking": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "firebase": "^11.9.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "~29.7",
    "jest-expo": "~55.0.16",
    "typescript": "~5.8.3"
  },
  "private": true
}
